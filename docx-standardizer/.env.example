# Pick one provider, fill the matching API key. See README "Providers" section.
LLM_PROVIDER=deepseek

# Optional: override the default model for the chosen provider.
# Format: <PROVIDER>_MODEL=... (or LLM_MODEL=... applies to whichever provider).
# DEEPSEEK_MODEL=deepseek-chat

# --- Per-provider keys (set the one(s) you'll use) ---
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
MINIMAX_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
