# Copy to .env and fill in actual keys. Do NOT commit .env.

# LLM provider (pick any)
DEEPSEEK_API_KEY=sk-...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Default LLM choice: deepseek | openai | anthropic
MNA_LLM_PROVIDER=deepseek

# DeepSeek model (default; OpenAI-compatible API at https://api.deepseek.com/v1)
# - deepseek-chat: V3, fast + cheap (~$0.14/M input, $0.28/M output as of 2026-04)
# - deepseek-reasoner: R1, slower + better reasoning, overkill for simple extraction
MNA_DEEPSEEK_MODEL=deepseek-chat

# OpenAI Batch API model (fallback)
MNA_OPENAI_MODEL=gpt-4o-mini

# Anthropic model (alternative for high-confidence subset)
MNA_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Fetcher tuning
MNA_HTTP_TIMEOUT_SECONDS=30
MNA_MAX_RETRIES=3
MNA_USER_AGENT=Mozilla/5.0 (compatible; mna-extractor/0.1; research)

# Output
MNA_OUTPUT_DIR=./data
