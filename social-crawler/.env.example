# Optional overrides — copy to .env to customize.
# All values shown are defaults; remove a line to keep the default.
# Demo scope: 2 platforms (twitter / tiktok).

LOG_LEVEL=INFO
DATA_DIR=./data

# Chrome CDP ports per platform (must match what start_chrome_cdp.py uses)
TWITTER_CDP_PORT=9223
TIKTOK_CDP_PORT=9225

# Override Chrome executable path (auto-detected on most systems)
# CHROME_PATH=/usr/bin/google-chrome
